@{
    Layout = null;
    ViewData["Title"] = "Admin Creado";
}

<!DOCTYPE html>
<html lang="es-AR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <title>@ViewData["Title"] - MotoRepuestos!</title>
</head>
<body class="bg-body-secondary">

    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-md-6 col-lg-5">
                <div class="card show">
                    <div class="card-body p-4 text-center">
                        <h2 class="card-title mb-4">Nuevo Admin Creado</h2>
                        <div class="d-grid gap-2">
                            <a class="btn btn-primary" href="/Account/CreateAdmin">Crear otro Admin</a>
                            <a class="btn btn-outline-secondary" href="/Account/Logout">Salir</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
