@model UserViewModel;
@{
    Layout = null;
    var formTitle = ViewData["FormTitle"]?.ToString() ?? "Crear Usuario";
    var formAction = ViewData["FormAction"]?.ToString() ?? "/Account/Register";
    var showLogoutButton = (ViewData["ShowLogoutButton"] as bool?) ?? false;
}

<!DOCTYPE html>
<html lang="es-AR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <title>@ViewData["Title"] - MotoRepuestos!</title>
</head>
<body class="bg-body-secondary">

    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">

            <div class="col-md-6 col-lg-4">
                <div class="card show">
                    <div class="card-body p-4">
                        <h2 class="card-title text-center mb-4">@formTitle</h2>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @TempData["ErrorMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form action="@formAction" method="post">
                            <div class="mb-3">
                                <label class="form-label">Nombre y Apellido</label>
                                <input class="form-control" type="text" asp-for="FullName" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input class="form-control" type="email" asp-for="Email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Contraseña</label>
                                <input class="form-control" type="password" asp-for="Password" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Repetir Contraseña</label>
                                <input class="form-control" type="password" asp-for="RepeatPassword" />
                                <span asp-validation-for="RepeatPassword" class="text-danger"></span>
                            </div>
                            <input type="hidden" asp-for="Type" />

                            <div class="d-grid gap-2">
                                <button class="btn btn-primary" type="submit">Continuar</button>
                                @if (showLogoutButton)
                                {
                                    <a href="/Account/Logout" class="btn btn-outline-secondary btn-sm">Salir</a>
                                }
                                else
                                {
                                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Volver</a>
                                }
                            </div>

                        </form>
                    </div>
                </div>
            </div>


        </div>
    </div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
