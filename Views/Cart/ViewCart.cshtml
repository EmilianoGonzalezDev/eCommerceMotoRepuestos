@model PagedResult<CartItemViewModel>;

@if (TempData["CartMessage"] is not null)
{
    <div class="alert alert-@(TempData["CartAlertType"] ?? "info") alert-dismissible fade show mt-4" role="alert">
        @TempData["CartMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.TotalItems != 0)
{
    <div class="row justify-content-between mt-4">
        <div class="col-4">
            <h4>Carrito</h4>
        </div>
        <div class="col-4 text-end">
            @if (User.Identity.IsAuthenticated)
            {
                <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#paymentDetailsModal">
                    Finalizar Compra
                </button>
            }
            else
            {
                <button disabled type="button" class="btn btn-secondary">
                    Finalizar Compra
                </button>

                <a href="/Account/Login" class="text-decoration-none">
                    <div class="alert alert-warning mt-1 text-center" role="alert">
                        Ingrese a su cuenta para finalizar compra
                    </div>
                </a>
            }
        </div>
    </div>
    <hr />

    <table class="table table-striped">
        <thead>
            <tr>

                <th style="width:120px"></th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Total</th>
                <th style="width:120px"></th>
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="align-middle">
                    <td style="width:120px">
                        <img class="card-img-top rounded" src="~/images/@(item.ImageName ?? "default.png")" alt="Product image"
                             loading="lazy" style="width:100px" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        <form action="/Cart/UpdateItemQuantity" method="post" class="d-inline-block">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="page" value="@Model.PageNumber" />
                            <input
                                class="form-control text-center"
                                style="max-width:6rem"
                                type="number"
                                name="quantity"
                                min="1"
                                value="@item.Quantity"
                                onchange="this.form.submit()" />
                        </form>
                    </td>
                    <td>@((item.Price * item.Quantity).ToString("C"))</td>


                    <td style="width:120px">
                        <a href="/Cart/RemoveItemToCart?productId=@item.ProductId&page=@Model.PageNumber" class="btn btn-sm btn-danger">
                            <i class="fa-solid fa-trash-can"></i>
                        </a>
                    </td>
                </tr>
            }


        </tbody>
    </table>
    <div class="d-flex justify-content-end mt-2">
        <h5>Total general: @(((decimal)ViewBag.OrderTotal).ToString("C"))</h5>
    </div>

    <nav aria-label="Paginación">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action("ViewCart", "Cart", new { page = Model.PageNumber - 1 }) : "#")">Anterior</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Url.Action("ViewCart", "Cart", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action("ViewCart", "Cart", new { page = Model.PageNumber + 1 }) : "#")">Siguiente</a>
            </li>
        </ul>
    </nav>
}

@if (Model.TotalItems == 0)
{
    <div class="alert alert-warning alert-dismissible fade show mt-4" role="alert">
        No hay productos en el carrito
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Modal -->
<div class="modal fade" id="paymentDetailsModal" tabindex="-1" aria-labelledby="paymentDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <form action="/Cart/PayNow" method="post">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="paymentDetailsModalLabel">Forma de pago</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">

                        <div class="col-12">
                            <input type="email" class="form-control" name="email" placeholder="Email" required maxlength="100" />
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control" name="address" placeholder="Dirección" required minlength="5" maxlength="120" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" name="country" placeholder="País" required minlength="2" maxlength="60" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" name="city" placeholder="Ciudad" required minlength="2" maxlength="60" />
                        </div>
                        <hr />
                        <div class="col-12">
                            <input type="text" class="form-control" name="cardHolderName" placeholder="Nombre del titular" required minlength="3" maxlength="100" />
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control" name="cardNumber" placeholder="Número de tarjeta" required inputmode="numeric" pattern="[0-9]{16}" maxlength="16" title="Ingresa 16 dígitos" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" name="expirationMonth" placeholder="MM" required min="1" max="12" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" name="expirationYear" placeholder="AAAA" required min="2022" max="2100" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" name="cvv" placeholder="CVV" required inputmode="numeric" pattern="[0-9]{3,4}" minlength="3" maxlength="4" title="Ingresa 3 o 4 dígitos" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary">Pagar</button>
                </div>
            </form>

        </div>
    </div>
</div>

