@using eCommerceMotoRepuestos.Enums
@model PagedResult<CartItemViewModel>;

@if (TempData["CartMessage"] is not null)
{
    <div class="alert alert-@(TempData["CartAlertType"] ?? "info") alert-dismissible fade show mt-4" role="alert">
        @TempData["CartMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.TotalItems != 0)
{
    <div class="row justify-content-between mt-4">
        <div class="col-4">
            <h4>Carrito</h4>
        </div>
        <div class="col-4 text-end">
            @if (User.Identity.IsAuthenticated && User.IsInRole("Client"))
            {
                <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#purchaseOptionsModal">
                    Finalizar Compra
                </button>
            }
            else
            {
                    <button disabled type="button" class="btn btn-secondary">
                        Finalizar Compra
                    </button>
            }

            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Login" class="text-decoration-none">
                    <div class="alert alert-warning mt-1 text-center" role="alert">
                        Ingrese a su cuenta para finalizar compra
                    </div>
                </a>
            }
        </div>
    </div>
    <hr />

    <table class="table table-striped">
        <thead>
            <tr>

                <th style="width:120px"></th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Total</th>
                <th style="width:120px"></th>
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="align-middle">
                    <td style="width:120px">
                        <img class="card-img-top rounded" src="~/images/@(item.ImageName ?? "default.png")" alt="Product image"
                             loading="lazy" style="width:100px" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        <form action="/Cart/UpdateItemQuantity" method="post" class="d-inline-block">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="page" value="@Model.PageNumber" />
                            <input
                                class="form-control text-center"
                                style="max-width:6rem"
                                type="number"
                                name="quantity"
                                min="1"
                                value="@item.Quantity"
                                onchange="this.form.submit()" />
                        </form>
                    </td>
                    <td>@((item.Price * item.Quantity).ToString("C"))</td>


                    <td style="width:120px">
                        <a href="/Cart/RemoveItemToCart?productId=@item.ProductId&page=@Model.PageNumber" class="btn btn-sm btn-danger">
                            <i class="fa-solid fa-trash-can"></i>
                        </a>
                    </td>
                </tr>
            }


        </tbody>
    </table>
    <div class="d-flex justify-content-end mt-2">
        <h5>Total general: @(((decimal)ViewBag.OrderTotal).ToString("C"))</h5>
    </div>

    <nav aria-label="Paginación">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action("ViewCart", "Cart", new { page = Model.PageNumber - 1 }) : "#")">Anterior</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Url.Action("ViewCart", "Cart", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action("ViewCart", "Cart", new { page = Model.PageNumber + 1 }) : "#")">Siguiente</a>
            </li>
        </ul>
    </nav>
}

@if (Model.TotalItems == 0)
{
    <div class="alert alert-warning alert-dismissible fade show mt-4" role="alert">
        No hay productos en el carrito
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Purchase Options Modal -->
<div class="modal fade" id="purchaseOptionsModal" tabindex="-1" aria-labelledby="purchaseOptionsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="purchaseOptionsModalLabel">Método de pago</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <button type="button" class="btn btn-primary btn-lg w-100" data-bs-toggle="modal" data-bs-target="#paymentDetailsModal" data-bs-dismiss="modal">
                    <i class="fa-solid fa-credit-card"></i>
                    Tarjeta de Crédito/Débito
                </button>
                <small class="text-muted d-block mb-3 mt-1 text-center">Dispones de 10 días para retirar tu compra.</small>

                <form action="/Cart/CompletePurchase" method="post">
                    <input type="hidden" name="paymentType" value="@((int)PaymentType.Store)" />
                    <button type="submit" class="btn btn-outline-primary btn-lg w-100 mt-2">
                        <i class="fa-solid fa-store"></i>
                        Pagar en Tienda
                    </button>
                </form>
                <small class="text-muted d-block mt-1 text-center">Dispones de 24 horas para retirar tu compra.</small>
            </div>
        </div>
    </div>
</div>

<!-- Payment Details Modal -->
<div class="modal fade" id="paymentDetailsModal" tabindex="-1" aria-labelledby="paymentDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <form id="cardPaymentForm" action="/Cart/CompletePurchase" method="post">
                <input type="hidden" name="paymentType" value="@((int)PaymentType.Card)" />
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="paymentDetailsModalLabel">Datos de Tarjeta</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <input type="text" class="form-control" id="cardHolderName" name="cardHolderName" placeholder="Nombre del titular" required minlength="3" maxlength="100" />
                        </div>
                        <div class="col-12">
                            <input type="text" class="form-control" id="cardNumber" name="cardNumber" placeholder="Número de tarjeta" required inputmode="numeric" pattern="[0-9]{4} [0-9]{4} [0-9]{4} [0-9]{4}" maxlength="19" title="Número no válido" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" id="expirationMonth" name="expirationMonth" placeholder="MM" required min="1" max="12" />
                        </div>
                        <div class="col-3">
                            <input type="number" class="form-control" id="expirationYear" name="expirationYear" placeholder="AAAA" required min="2022" max="2100" />
                        </div>
                        <div class="col-6">
                            <input type="text" class="form-control" id="cvv" name="cvv" placeholder="CVV" required inputmode="numeric" pattern="[0-9]{3,4}" minlength="3" maxlength="4" title="Ingresa 3 o 4 dígitos" />
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end mt-2 me-2">
                    <h6>Total: @(((decimal)ViewBag.OrderTotal).ToString("C"))</h6>
                </div>
                <div class="px-3">
                    <div id="paymentProcessingContainer" class="d-none mt-2" aria-live="polite" aria-atomic="true">
                        <small class="text-muted d-block mb-1">Procesando el pago...</small>
                        <div class="progress" role="progressbar" aria-label="Procesando el pago" aria-valuemin="0" aria-valuemax="100">
                            <div id="paymentProcessingBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%;">0%</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button id="payButton" type="submit" class="btn btn-primary">Pagar</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    //Payment Progress Bar
    (function () {
        const form = document.getElementById("cardPaymentForm");
        const processingContainer = document.getElementById("paymentProcessingContainer");
        const processingBar = document.getElementById("paymentProcessingBar");
        const payButton = document.getElementById("payButton");
        const modalElement = document.getElementById("paymentDetailsModal");

        if (!form || !processingContainer || !processingBar || !payButton || !modalElement) {
            return;
        }

        let progressIntervalId = null;
        let submitTimeoutId = null;

        const resetProcessingState = function () {
            if (progressIntervalId) {
                clearInterval(progressIntervalId);
                progressIntervalId = null;
            }

            if (submitTimeoutId) {
                clearTimeout(submitTimeoutId);
                submitTimeoutId = null;
            }

            form.dataset.allowSubmit = "false";
            payButton.disabled = false;
            processingContainer.classList.add("d-none");
            processingBar.style.width = "0%";
            processingBar.textContent = "0%";
        };

        form.dataset.allowSubmit = "false";

        form.addEventListener("submit", function (event) {
            if (form.dataset.allowSubmit === "true") {
                return;
            }

            if (!form.checkValidity()) {
                return;
            }

            event.preventDefault();

            payButton.disabled = true;
            processingContainer.classList.remove("d-none");

            let currentProgress = 0;

            progressIntervalId = setInterval(function () {
                currentProgress = Math.min(100, currentProgress + 40);
                const percentage = Math.round(currentProgress);
                processingBar.style.width = percentage + "%";
                processingBar.textContent = percentage + "%";
            }, 40);

            submitTimeoutId = setTimeout(function () {
                clearInterval(progressIntervalId);
                progressIntervalId = null;
                processingBar.style.width = "100%";
                processingBar.textContent = "100%";
                form.dataset.allowSubmit = "true";
                form.requestSubmit();
            }, 2000);
        });

        modalElement.addEventListener("hidden.bs.modal", resetProcessingState);
    })();
</script>

<script>
    document.getElementById("cardNumber").addEventListener("input", function(e) {
      let value = e.target.value.replace(/\D/g, ""); // Remove everything that is not a number.
      let formattedValue = value.match(/.{1,4}/g)?.join(" ") || ""; // Separate into groups of 4 characters
      e.target.value = formattedValue;
    });
</script>
