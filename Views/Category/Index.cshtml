@model List<CategoryViewModel>

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Categorías</h4>
    </div>
    <div class="col-4 text-end">
        <a href="/Category/Add" class="btn btn-success"><i class="fa-solid fa-plus"></i>Agregar</a>
    </div>
</div>

<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th style="width: 120px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td style="width: 120px;">
                    <a href="/Category/Edit/@item.CategoryId" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen"></i></a>
                    @if (item.IsActive)
                    {
                        <a href="#" class="btn btn-danger btn-sm" onclick="toggleItem(@item.CategoryId, @(item.IsActive.ToString().ToLower()))"><i class="fa-solid fa-trash"></i></a>
                    }
                    else
                    {
                        <a href="#" class="btn btn-success btn-sm" onclick="toggleItem(@item.CategoryId, @(item.IsActive.ToString().ToLower()))"><i class="fa-solid fa-arrow-rotate-left"></i></a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        function toggleItem(id, isActive)
        {
            const confirmText = isActive ? "Si, Dar de baja!" : "Si, Reactivar!";
            const titleText = isActive ? "Estás seguro?" : "Reactivar categoría?";
            const iconType = isActive ? "warning" : "question";
            Swal.fire({
            title: titleText,
            icon: iconType,
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: confirmText,
            cancelButtonText: "No, Regresar"
            }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = `/Category/ToggleStatus/${id}`;
            }
            });
        }
    </script>
}
