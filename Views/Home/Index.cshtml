@model CatalogViewModel;
@{
    ViewData["Title"] = "Moto Repuestos!";
}

<div class="row p-5 bg-light mt-4">
    <div class="col-sm-12 col-md-3 col-lg-3">
        <div class="d-grid">
            <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#filterByCategoriesModal">
                Categorías
            </button>
        </div>
    </div>

    <div class="col-sm-12 col-md-9 col-lg-9">
        <form action="/Home/FilterBySearch" method="get">
            <div class="input-group">
                <input type="text" class="form-control" name="value" autocomplete="off" placeholder="żQué estás buscando?" value="@Model.SearchValue" />
                <button class="btn btn-outline-secondary" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
        </form>

    </div>
</div>
@if (Model.FilterBy != "" && Model.FilterBy != null)
{
    <div class="row bg-light p-2 mt-2">
        <div class="col-sm-12">
            @Model.FilterBy
        </div>
    </div>
}

<div class="row row-cols-3 row-cols-sm-3 row-cols-md-4 g-4 py-4">
    @foreach (var p in Model.Products.Items)
    {
        <div class="col">
            <div class="card shadow-sm h-100">
                <img class="card-img-top catalog-card-img" src="~/images/@(string.IsNullOrWhiteSpace(p.ImageName) ? "default.png" : p.ImageName)" alt="@p.Name" />
                <div class="card-body p-4 catalog-card-body">
                    <div class="text-center catalog-card-info">
                        <h5 class="fw-bolder catalog-card-title">@p.Name</h5>
                        <div class="catalog-card-price">@p.Price.ToString("C")</div>
                    </div>
                </div>
                <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                    <div class="text-center">
                        <a class="btn btn-outline-dark mt-auto stretched-link" href="/Home/ProductDetail?id=@p.ProductId" role="button">Ver Detalles</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

    @{
    var totalPages = Model.Products.TotalPages == 0 ? 1 : Model.Products.TotalPages;
    Func<int, string> pageUrl = (p) =>
    {
        if (!string.IsNullOrWhiteSpace(Model.SearchValue))
        {
            return Url.Action("FilterBySearch", "Home", new { value = Model.SearchValue, page = p }) ?? "#";
        }
        if (Model.CategoryFilterId != 0)
        {
            return Url.Action("FilterByCategory", "Home", new { id = Model.CategoryFilterId, name = Model.FilterBy, page = p }) ?? "#";
        }
        return Url.Action("Index", "Home", new { page = p }) ?? "#";
    };
}

<nav aria-label="Paginación">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.Products.HasPrevious ? "" : "disabled")">
            <a class="page-link" href="@(Model.Products.HasPrevious ? pageUrl(Model.Products.PageNumber - 1) : "#")">Anterior</a>
        </li>
        @for (var i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == Model.Products.PageNumber ? "active" : "")">
                <a class="page-link" href="@pageUrl(i)">@i</a>
            </li>
        }
        <li class="page-item @(Model.Products.HasNext ? "" : "disabled")">
            <a class="page-link" href="@(Model.Products.HasNext ? pageUrl(Model.Products.PageNumber + 1) : "#")">Siguiente</a>
        </li>
    </ul>
</nav>
<!-- Modal "Filter by Categories" -->
<div class="modal fade" id="filterByCategoriesModal" tabindex="-1" aria-labelledby="filterByCategories" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="filterByCategories">Categorías</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row row-cols-2 g-2">
                    <div class="col d-grid">
                        <a class="btn btn-outline-dark"
                           asp-controller="Home" asp-action="FilterByCategory"
                           asp-route-id="0"
                           asp-route-name="All Categories">Todas las categorías
                        </a>
                    </div>
                    @foreach (var category in Model.Categories)
                    {
                        <div class="col d-grid">
                            <a class="btn btn-outline-dark"
                               asp-controller="Home" asp-action="FilterByCategory"
                               asp-route-id="@category.CategoryId"
                               asp-route-name="@category.Name">@category.Name
                            </a>
                        </div>
                    }
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
