@model ProductViewModel;
@{
    var isOutOfStock = Model.Stock == 0;
    var isUnavailable = isOutOfStock || !Model.IsActive;
    var returnUrl = ViewBag.ReturnUrl as string;
    var message = TempData["ProductDetailMessage"] as string;
    var alertType = TempData["ProductDetailAlertType"] as string ?? "success";
}

<section class="py-5 bg-body-tertiary">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row g-4 g-lg-5 align-items-center">
            <div class="col-md-6">
                <img class="card-img-top rounded mb-5" src="~/images/@(string.IsNullOrWhiteSpace(Model.ImageName) ? "default.png" : Model.ImageName)" alt="@Model.Name" loading="lazy" />
            </div>
            <div class="col-md-6">
                <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                <div class="fs-5">
                    <span class="text-primary fw-semibold ms-2">@Model.Price.ToString("C")</span>
                </div>
                <div class="text-end mb-2">
                    <small class="text-muted fw-light">Producto #@Model.ProductId</small>
                </div>
                @Html.Raw(Model.Description)
                @if (isOutOfStock)
                {
                    <div class="alert alert-warning mt-3" role="alert">
                        Sin stock.
                    </div>
                }
                @if (!Model.IsActive)
                {
                    <div class="alert alert-warning mt-3" role="alert">
                        Producto no disponible.
                    </div>
                }

                <form asp-controller="Cart" asp-action="AddItemToCart" method="post" id="addToCartForm">
                    <div class="d-flex align-items-center gap-3">
                        <input hidden name="productId" asp-for="@Model.ProductId" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <input class="form-control text-center py-2" name="quantity" type="number" value="1" min="1" max="@Model.Stock" style="max-width:5rem" disabled="@isUnavailable" />
                        <button class="btn btn-dark flex-xl-shrink-0 px-4" type="submit" disabled="@isUnavailable">
                            <i class="fa-solid fa-cart-shopping"></i>
                            Agregar al carrito
                        </button>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-primary flex-md-shrink-0 px-4"
                               asp-controller="Product"
                               asp-action="Edit"
                               asp-route-id="@Model.ProductId">Editar</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(returnUrl))
                        {
                            <a class="btn btn-warning flex-md-shrink-0 px-4" href="@returnUrl">Volver</a>
                        }
                        else
                        {
                            <a class="btn btn-warning flex-md-shrink-0 px-4" href="javascript:history.back();">Volver</a>
                        }
                    </div>
                </form>
                <div id="quantityUnavailableAlert" class="alert alert-warning mt-3 d-none" role="alert">
                    Stock disponible: <span id="quantityUnavailableAlertMax"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-@alertType alert-dismissible fade show mt-1" role="alert">
                        @message
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<script>
    (() => {
        const form = document.getElementById("addToCartForm");
        if (!form) {
            return;
        }

        const quantityInput = form.querySelector('input[name="quantity"]');
        const unavailableAlert = document.getElementById("quantityUnavailableAlert");
        const unavailableAlertMax = document.getElementById("quantityUnavailableAlertMax");
        if (!quantityInput || !unavailableAlert || !unavailableAlertMax) {
            return;
        }

        form.addEventListener("submit", (event) => {
            const quantity = Number(quantityInput.value);
            const max = Number(quantityInput.max);

            if (!Number.isNaN(quantity) && !Number.isNaN(max) && quantity > max) {
                event.preventDefault();
                unavailableAlertMax.textContent = max.toString();
                unavailableAlert.classList.remove("d-none");
                return;
            }

            unavailableAlert.classList.add("d-none");
        });
    })();
</script>
