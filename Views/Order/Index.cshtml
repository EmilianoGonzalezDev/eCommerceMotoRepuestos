@model PagedResult<OrderViewModel>
@using eCommerceMotoRepuestos.Enums
@{
    var selectedStatuses = (ViewBag.SelectedStatuses as HashSet<int>) ?? new HashSet<int>();
    var selectedStatusValues = selectedStatuses.ToArray();

    string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Prepared => "bg-info text-dark",
        OrderStatus.Delivered => "bg-success",
        OrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Pedidos</h4>
    </div>
</div>
<hr />

<form method="get" action="/Orders" class="row g-2 align-items-end mt-2 mb-4">
    <input type="hidden" name="page" value="1" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
    <input type="hidden" name="filtersSubmitted" value="true" />

    @foreach (var status in Enum.GetValues<OrderStatus>())
    {
        var statusValue = (int)status;
        <div class="col-auto">
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="selectedStatuses"
                       value="@statusValue"
                       id="status_@statusValue"
                       checked="@selectedStatuses.Contains(statusValue)" />
                <label class="form-check-label" for="status_@statusValue">
                    @status.GetDisplayName()
                </label>
            </div>
        </div>
    }
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">Aplicar filtros</button>
    </div>
</form>

@if (Model.TotalItems == 0)
{
    <div class="alert alert-warning mt-4" role="alert">
        No se registran pedidos.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Fecha de compra</th>
                <th>Pedido N°</th>
                <th>Cliente</th>
                <th>Pago</th>
                <th>Total</th>
                <th>Productos</th>
                <th>Estado</th>
            </tr>

        </thead>
        <tbody>
            @foreach (var order in Model.Items)
            {
                <tr>
                    <td>@order.OrderDateFormatted</td>
                    <td>#@order.OrderId</td>
                    <td>@order.CustomerName</td>
                    <td>@order.PaymentType.GetDisplayName()</td>
                    <td>@order.TotalAmountFormatted</td>
                    <td>
                        <ul>
                            @foreach (var orderItem in order.OrderItems)
                            {
                                <li class="list-group-item">
                                    @orderItem.Quantity x
                                    <a asp-controller="Home" asp-action="ProductDetail" asp-route-id="@orderItem.ProductId"
                                       class="text-decoration-none fw-bold"
                                    >
                                        @orderItem.ProductName
                                    </a>
                                    @orderItem.FormattedPrice
                                </li>
                            }
                        </ul>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge @GetStatusBadgeClass(order.Status)">@order.Status.GetDisplayName()</span>
                            <button type="button"
                                    class="btn btn-link p-0 text-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editStatusModal_@order.OrderId"
                                    title="Editar estado"
                                    aria-label="Editar estado del pedido @order.OrderId">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                        </div>

                        <div class="modal fade" id="editStatusModal_@order.OrderId" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Editar estado del pedido #@order.OrderId</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <form asp-controller="Order" asp-action="UpdateStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <div class="modal-body">
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <input type="hidden" name="page" value="@Model.PageNumber" />
                                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                            <input type="hidden" name="filtersSubmitted" value="true" />
                                            @foreach (var selectedStatus in selectedStatusValues)
                                            {
                                                <input type="hidden" name="selectedStatuses" value="@selectedStatus" />
                                            }
                                            <label class="form-label" for="statusSelect_@order.OrderId">Estado</label>
                                            <select class="form-select" id="statusSelect_@order.OrderId" name="status">
                                                @foreach (var status in Enum.GetValues<OrderStatus>())
                                                {
                                                    if (status == order.Status)
                                                    {
                                                        <option value="@status" selected>@status.GetDisplayName()</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@status">@status.GetDisplayName()</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                                            <button type="submit" class="btn btn-primary">Guardar</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-end align-items-center mb-2">
        <span class="small text-muted me-2">Items por pagina</span>
        <form method="get" action="/Orders" class="d-inline">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="filtersSubmitted" value="true" />
            @foreach (var selectedStatus in selectedStatusValues)
            {
                <input type="hidden" name="selectedStatuses" value="@selectedStatus" />
            }
            <select name="pageSize" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                @await Html.PartialAsync("_PageSizeOptions", Model.PageSize)
            </select>
        </form>
    </div>
    <nav aria-label="Paginacion">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action("Index", "Order", new { page = Model.PageNumber - 1, pageSize = Model.PageSize, selectedStatuses = selectedStatusValues, filtersSubmitted = true }) : "#")">Anterior</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Order", new { page = i, pageSize = Model.PageSize, selectedStatuses = selectedStatusValues, filtersSubmitted = true })">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action("Index", "Order", new { page = Model.PageNumber + 1, pageSize = Model.PageSize, selectedStatuses = selectedStatusValues, filtersSubmitted = true }) : "#")">Siguiente</a>
            </li>
        </ul>
    </nav>
}
