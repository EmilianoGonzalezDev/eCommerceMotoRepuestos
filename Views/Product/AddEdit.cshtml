@model ProductViewModel;

@{
    var tilte = Model.ProductId is 0 ? "Nuevo Producto" : "Editar Producto";
    var btnAction = Model.ProductId is 0 ? "Agregar" : "Guardar";
    var previewImage = string.IsNullOrWhiteSpace(Model.ImageName) ? "default.png" : Model.ImageName;
}


<div class="row">

    @if (ViewBag.message != null)
    {
        <div class="alert alert-success" role="alert">
            @ViewBag.message
        </div>
    }

    <h2>@tilte</h2>
    <hr />
    <div class="col-md-6">

        <form asp-action="@(Model.ProductId is 0 ? "Add" : "Edit")" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ImageName" />

            <div class="mb-3">
                <label class="form-label">Categoría</label>
                <select class="form-select" asp-for="Category.CategoryId" asp-items="@Model.Categories">
                    <option value="" selected disabled>--seleccionar--</option>
                </select>
                <span asp-validation-for="Category.CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input type="text" class="form-control" asp-for="Name" autocomplete="off">
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <textarea id="summernote" class="form-control" asp-for="Description" autocomplete="off">
                </textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Precio</label>
                <input type="number" class="form-control" asp-for="Price" autocomplete="off">
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Stock</label>
                <input type="number" class="form-control" asp-for="Stock" autocomplete="off">
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Subir Imagen</label>
                <input type="file" class="form-control" asp-for="ImageFile" id="imageFileInput" accept="image/*">
            </div>

            <div class="mb-3 d-md-none">
                <img src="~/images/@previewImage" id="previewImageMobile" class="rounded card-img-top" loading="lazy" alt="@Model.Name" />
            </div>

            <div class="d-grid gap-2 d-md-block mt-4">
                <button class="btn btn-primary" type="submit">@btnAction</button>
                <a href="javascript:history.back();" class="btn btn-warning">Volver</a>
            </div>
        </form>
    </div>

    <div class="col-md-6 d-none d-md-block">
        <img src="~/images/@previewImage" id="previewImageDesktop" class="rounded card-img-top" loading="lazy" alt="@Model.Name" />
    </div>
</div>

@section Styles {
    <link href="~/lib/summernote/dist/summernote.min.css" rel="stylesheet" />
    <link href="~/lib/summernote/dist/summernote-bs5.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/lib/summernote/dist/summernote.min.js"></script>
    <script src="~/lib/summernote/dist/summernote-bs5.min.js"></script>

    <script>
        $( document ).ready(function() {
            
            //Initialize summernote
            $( '#summernote' ).summernote();

            // Manage the product image (default, selected, original) in the form
            const imageFileInput = document.getElementById('imageFileInput');
            const previewImages = [
                document.getElementById('previewImageMobile'),
                document.getElementById('previewImageDesktop')
            ].filter(Boolean);
            const basePreviewSrc = previewImages[0]?.src;
            let currentObjectUrl = null;

            imageFileInput?.addEventListener('click', function () {
                imageFileInput.value = '';
                if (basePreviewSrc) {
                    previewImages.forEach(img => img.src = basePreviewSrc);
                }
                if (currentObjectUrl) {
                    URL.revokeObjectURL(currentObjectUrl);
                    currentObjectUrl = null;
                }
            });
            imageFileInput?.addEventListener('change', function (event) {
                const file = event.target.files?.[0];
                if (!file) {
                    if (basePreviewSrc) {
                        previewImages.forEach(img => img.src = basePreviewSrc);
                    }
                    return;
                }
                if (currentObjectUrl) {
                    URL.revokeObjectURL(currentObjectUrl);
                }
                currentObjectUrl = URL.createObjectURL(file);
                previewImages.forEach(img => img.src = currentObjectUrl);
            });

        });
    </script>
}
