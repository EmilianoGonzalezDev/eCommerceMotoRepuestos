@model PagedResult<ProductViewModel>

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Productos</h4>
    </div>
    <div class="col-4 text-end">
        <a href="/Product/Add" class="btn btn-success"><i class="fa-solid fa-plus"></i>Agregar</a>
    </div>
 </div>

<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>CategorÌa</th>
            <th>Precio</th>
            <th>Stock</th>
            <th style="width: 120px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category.Name</td>
                <td>@item.Price</td>
                <td>@item.Stock</td>
                <td style="width: 120px;">
                    <a href="/Product/Edit/@item.ProductId" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen"></i></a>
                    @if (item.IsActive)
                    {
                        <a href="#" class="btn btn-danger btn-sm" onclick="toggleItem(@item.ProductId, @(item.IsActive.ToString().ToLower()))"><i class="fa-solid fa-trash"></i></a>
                    }
                    else
                    {
                        <a href="#" class="btn btn-success btn-sm" onclick="toggleItem(@item.ProductId, @(item.IsActive.ToString().ToLower()))"><i class="fa-solid fa-arrow-rotate-left"></i></a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-end align-items-center mb-2">
    <span class="small text-muted me-2">Items por p·gina</span>
    <form method="get" action="/Product/Index" class="d-inline">
        <input type="hidden" name="page" value="1" />
        <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            @await Html.PartialAsync("_PageSizeOptions", Model.PageSize)
        </select>
    </form>
</div>

    <nav aria-label="PaginaciÛn">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action("Index", "Product", new { page = Model.PageNumber - 1, pageSize = Model.PageSize }) : "#")">Anterior</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Product", new { page = i, pageSize = Model.PageSize })">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action("Index", "Product", new { page = Model.PageNumber + 1, pageSize = Model.PageSize }) : "#")">Siguiente</a>
            </li>
        </ul>
    </nav>
@section Scripts {
    <script>
        function toggleItem(id, isActive)
        {
            const confirmText = isActive ? "Si, Dar de baja!" : "Si, Reactivar!";
            const titleText = isActive ? "Est·s seguro?" : "Reactivar producto?";
            const iconType = isActive ? "warning" : "question";
            Swal.fire({
            title: titleText,
            icon: iconType,
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: confirmText,
            cancelButtonText: "No, Regresar"
            }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = `/Product/ToggleStatus/${id}`;
            }
            });
        }
    </script>
}
