@model StockSettingsViewModel

<div class="row mt-4">
    <div class="col-md-6">
        <h4>Configuraciones</h4>
        <hr />

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="Index" method="post">
            <div class="mb-3">
                <label asp-for="LowStockThreshold" class="form-label"></label>
                <input asp-for="LowStockThreshold" type="number" min="1" class="form-control" />
                <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-block mt-4">
                <button class="btn btn-primary" type="submit">Guardar</button>
            </div>
        </form>
    </div>
</div>
