@model PagedResult<OrderViewModel>

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Mis Pedidos</h4>
    </div>
</div>
<hr />

<table class="table table-striped">
    <thead>
        <tr>
            <th>Fecha de compra</th>
            <th>Total</th>
            <th>Productos</th>
        </tr>

    </thead>
    <tbody>
        @foreach (var order in Model.Items)
        {
            <tr>
                <td>@order.OrderDateFormatted</td>
                <td>@order.TotalAmountFormatted</td>
                <td>
                    <ul>
                        @foreach (var orderItem in order.OrderItems)
                        {
                            <li class="list-group-item">
                                @orderItem.OrderItemSummary
                            </li>
                        }
                    </ul>
                </td>
            </tr>
        }
    </tbody>
</table>
@if (Model.TotalPages > 1)
{
    <nav aria-label="Paginaciˇn">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action("MyOrders", "User", new { page = Model.PageNumber - 1 }) : "#")">Anterior</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Url.Action("MyOrders", "User", new { page = i })">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action("MyOrders", "User", new { page = Model.PageNumber + 1 }) : "#")">Siguiente</a>
            </li>
        </ul>
    </nav>
}

